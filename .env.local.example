# Supabase Configuration (SSR-compatible)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key-here

# Google Maps API
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# App Configuration
NEXT_PUBLIC_APP_NAME=TeeFlow
NEXT_PUBLIC_SCRAPER_TIMEOUT_MS=30000

# Note: Copy this to .env.local and fill in your real values
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY is the public/anon key (safe to expose)
# Do NOT commit .env.local to git
